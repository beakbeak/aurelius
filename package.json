{
  "type": "module",
  "dependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "@types/wicg-mediasession": "^1.1.8",
    "svelte": "^5.55.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2",
    "vite": "^8.0.3"
  },
  "devDependencies": {
    "@playwright/cli": "^0.1.1",
    "jsdom": "^26.0.0",
    "mocha": "^11.7.5",
    "mocha-suppress-logs": "^0.6.0",
    "nyc": "^17.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0"
  },
  "scripts": {
    "gobuild": "go build -tags sqlite_fts5 ./cmd/aurelius",
    "gotest": "LSAN_OPTIONS=suppressions=${PWD}/test/lsan.supp go test -tags sqlite_fts5 -asan ./...",
    "build": "vite build",
    "build-debug": "vite build --mode development --minify false",
    "mocha": "mocha --require mocha-suppress-logs",
    "test": "killall aurelius; go run ./cmd/aurelius -log error -media test/media -storage test/storage & npm run mocha; killall aurelius",
    "coverage": "nyc --reporter=lcov --reporter=text mocha"
  },
  "mocha": {
    "extension": [
      "ts"
    ],
    "spec": "ts/**/*.spec.ts",
    "require": [
      "tsx/cjs"
    ]
  }
}
